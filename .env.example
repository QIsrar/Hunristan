# =================================================================
# SMART HUNRISTAN — Environment Variables
# Copy this to .env.local and fill in your values
# =================================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Code Execution (free, no key needed)
NEXT_PUBLIC_PISTON_API_URL=https://emkc.org/api/v2/piston

# AI Code Review - Google Gemini (free tier)
GEMINI_API_KEY=your-gemini-api-key

# Custom AI Model (optional, takes priority over Gemini)
CUSTOM_AI_GRADER_URL=https://your-ai-model.com/grade
CUSTOM_AI_GRADER_KEY=your-model-key
WEBHOOK_SECRET=your-webhook-secret

# Email (Gmail SMTP - optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Smart Hunristan <noreply@smarthunristan.com>

# Admin Setup - run POST /api/setup-admin once after deploy
SETUP_SECRET=change-this-long-random-string

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_EMAIL=qisrar951@gmail.com
NODE_ENV=development
